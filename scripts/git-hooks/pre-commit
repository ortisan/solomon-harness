#!/bin/sh

# Solomon Harness Local Pre-Commit Validation Loop
echo "=== Running pre-commit validation loop ==="

# 1. Update skills documentation
echo "Auto-documenting specialist skills..."
uv run python scripts/document-skills.py || { echo "Error: Skill auto-documentation failed."; exit 1; }

# 2. Compile: scaffold agents and regenerate host-tool integrations
echo "Compiling specialist agent harnesses..."
uv run python -m solomon_harness.cli compile || { echo "Error: Harness compilation failed."; exit 1; }

# 3. Run full project test suite
# Strip the GIT_* redirectors git exports while this hook runs. Left in the
# environment they override "git -C <path>" inside tests that shell out to git,
# pointing those commands at the repo being committed instead of each test's own
# temp repo (see bug-test-isolation). Unsetting them runs the suite in a clean
# git environment.
echo "Running project test suite..."
env -u GIT_DIR -u GIT_WORK_TREE -u GIT_INDEX_FILE -u GIT_PREFIX \
    -u GIT_COMMON_DIR -u GIT_OBJECT_DIRECTORY -u GIT_ALTERNATE_OBJECT_DIRECTORIES \
    uv run python -m unittest discover -s tests || { echo "Error: Test suite execution failed."; exit 1; }

echo "=== All pre-commit validations passed successfully! ==="
exit 0
