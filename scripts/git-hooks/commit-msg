#!/usr/bin/env python3
import sys
import re
import unicodedata

def main():
    if len(sys.argv) < 2:
        print("Usage: commit-msg <commit-msg-file>", file=sys.stderr)
        sys.exit(1)

    commit_msg_filepath = sys.argv[1]
    try:
        with open(commit_msg_filepath, 'r', encoding='utf-8') as f:
            lines = f.readlines()
    except Exception as e:
        print(f"Error reading commit message file: {e}", file=sys.stderr)
        sys.exit(1)

    # Filter out comments strictly starting with Git's default # prefix
    non_comment_lines = [line for line in lines if not line.startswith('#')]
    commit_msg = "".join(non_comment_lines).strip()

    if not commit_msg:
        # Empty commit message, let git handle or reject it
        sys.exit(0)

    # Check for emojis or icons in the entire commit message
    for char in commit_msg:
        cp = ord(char)
        # Check standard emoji / symbol blocks
        is_emoji = (0x1F000 <= cp <= 0x1FFFF) or (0x2600 <= cp <= 0x27BF) or (0x2300 <= cp <= 0x23FF)
        if not is_emoji:
            try:
                cat = unicodedata.category(char)
                if cat == 'So':  # Symbol, other
                     is_emoji = True
                else:
                     name = unicodedata.name(char, "").upper()
                     if any(word in name for word in ("EMOJI", "SMILEY", "PICTOGRAPH")):
                         is_emoji = True
            except Exception:
                pass
        
        if is_emoji:
            print("Error: Commit message contains emojis or icons, which are not allowed.", file=sys.stderr)
            print("Please remove any emojis or symbols and try again.", file=sys.stderr)
            sys.exit(1)

    # Extract first line (subject)
    msg_lines = commit_msg.split('\n')
    subject = msg_lines[0].strip()

    # Validate against conventional commits pattern with non-greedy scope matching
    pattern_str = r'^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|hypothesis)(\([^)]+\))?: .{1,100}$'
    if not re.match(pattern_str, subject):
        print("Error: Commit message subject line does not conform to Conventional Commits.", file=sys.stderr)
        print("", file=sys.stderr)
        print("Format expected:", file=sys.stderr)
        print("  <type>(<scope>): <subject>", file=sys.stderr)
        print("or", file=sys.stderr)
        print("  <type>: <subject>", file=sys.stderr)
        print("", file=sys.stderr)
        print("Where:", file=sys.stderr)
        print("  - <type> is one of: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert, hypothesis", file=sys.stderr)
        print("  - <scope> is optional (e.g., feat(parser): add support for JSON)", file=sys.stderr)
        print("  - <subject> is a description between 1 and 100 characters, starting with a space after the colon.", file=sys.stderr)
        print("  - The message must NOT contain emojis or icons.", file=sys.stderr)
        print("", file=sys.stderr)
        print(f"Your subject was:\n  \"{subject}\"", file=sys.stderr)
        sys.exit(1)

    sys.exit(0)

if __name__ == '__main__':
    main()

