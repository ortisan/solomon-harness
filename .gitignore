tmp/
.DS_Store
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.mypy_cache/
.ruff_cache/
*.egg-info/
node_modules/

# solomon-dev npm CLI: templates/ is a generated, vendored copy of this repo
# (sync-templates.js / npm prepack regenerate it), so it is not tracked.
solomon_dev/templates/
solomon_dev/node_modules/

# Compiled agent harnesses. Source lives under agents/; the compiler writes the
# composed instruction files here, so this is build output and is not tracked.
build/

# Local agent memory stores, at any depth (root or per-agent harness)
**/memory/long_term/*.db
**/memory/short_term/*.json
**/memory/surrealdb/
*.db-wal
*.db-shm

# Encrypted secret vaults, at any depth
**/.agent/secure_vault.enc
