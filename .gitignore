tmp/
.DS_Store
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.mypy_cache/
.ruff_cache/
*.egg-info/
node_modules/

# Compiled agent harnesses. Source lives under agents/; the compiler writes the
# composed instruction files here, so this is build output and is not tracked.
build/

# Local agent memory stores, at any depth (root or per-agent harness)
**/memory/long_term/*.db
**/memory/short_term/*.json
**/memory/surrealdb/
**/memory/spectron/
/memory/
*.db-wal
*.db-shm

# Stray root-level database files from manual debugging sessions (no code path
# writes here; the canonical SQLite fallback lives under memory/long_term/)
/*.db

# Session working notes (review verdicts, PR diffs, ad hoc scripts); local state,
# never source
/scratch/

# Test coverage database
.coverage

# Encrypted secret vaults, at any depth
**/.agent/secure_vault.enc

# Local lifecycle state: handoff contract artifacts written between workflow stages
.solomon/

# Per-branch planning artifact: PLAN.md is written locally by /solomon-start for
# the branch in flight, not shared source. Tracking it made every concurrent
# branch rewrite and collide on it, so it is local state, never committed.
PLAN.md

# Git Worktrees
ui-worktree/

# Generated living-wiki overview (regenerated on each init/release)
docs/wiki/Code-Overview.md

