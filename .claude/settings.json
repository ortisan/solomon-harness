{
  "$schema": "https://raw.githubusercontent.com/anthropic-cookbook/claude-code/main/schema/settings.schema.json",
  "watch": true,
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  }
}
